# ── Supabase (Projekt-Einstellungen → API) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Bunny Stream (bunny.net → Stream → Video Library) ───────────────
# ID der Video Library (Zahl, steht in der URL / API-Übersicht)
BUNNY_LIBRARY_ID=12345
# API Key der Video Library (Library → API)
BUNNY_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Token Authentication Key (Library → Security → "Embed View Token Authentication" aktivieren!)
BUNNY_TOKEN_AUTH_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# CDN-Hostname der Library (Library → API → CDN Hostname), z.B. vz-abc123-456.b-cdn.net
BUNNY_CDN_HOSTNAME=vz-xxxxxxxx-xxx.b-cdn.net
